general {
    colors = true
    interval = 5
}

order += "battery all"
order += "tztime local"

battery all {
    format = "%status %percentage"
    format_down = "No battery"

    status_chr = "CHR"
    status_bat = "BAT"
    status_full = "FULL"

    # THIS is what makes charging green
    charging_color = "#00ff00"
    full_color = "#00ff00"
    color_bad = "#ff5555"
}

tztime local {
    format = "%H:%M"
}
