general {
    colors = true
    interval = 5
}

order += "volume master"
order += "battery all"
order += "tztime local"

volume master {
    format = "%volume"
    format_muted = "muted(%volume)"
    device = "default"
    mixer = "Master"
    mixer_idx = 0
}
battery all {
    format = "%status %percentage"
    status_chr = "CHR"
    status_bat = "BAT"
    last_full_capacity = true
    integer_battery_capacity = true
}

tztime local {
    format = "%H:%M"
}
